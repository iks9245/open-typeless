# whisper.cpp local ASR server configuration
# Copy this file to .env and adjust as needed

# URL of the running whisper.cpp server (default: http://localhost:8080)
# Start the server with: ./server -m models/ggml-base.bin --port 8080
WHISPER_SERVER_URL=http://localhost:8080

# Language hint for whisper (optional — leave unset for auto-detect)
# Examples: zh, en, ja, ko
# WHISPER_LANGUAGE=zh

# ── Volcengine cloud ASR (unused by default, kept for reference) ──────────────
# VOLCENGINE_APP_ID=your_app_id_here
# VOLCENGINE_ACCESS_TOKEN=your_access_token_here
# VOLCENGINE_RESOURCE_ID=volc.bigasr.sauc.duration
